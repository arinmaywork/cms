# ════════════════════════════════════════════════════════════════
#  .env.example — copy to .env and fill in your real credentials
#  DO NOT commit .env to version control!
# ════════════════════════════════════════════════════════════════

# ── Google Gemini (AI copy) — free key: https://aistudio.google.com/apikey ────
GEMINI_API_KEY=

# ── Instagram Graph API (Instagram Login token — starts with IGAA) ────────────
# The app auto-refreshes this weekly and writes the new token back here.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ── Cloudinary (public image URLs for Instagram) ──────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Behance (Playwright automation) ───────────────────────────────────────────
BEHANCE_EMAIL=
BEHANCE_PASSWORD=
BEHANCE_CATEGORY=Photography
BEHANCE_TOOLS=CAPTURE ONE,FUJIFILM XT30

# ── YouTube (see YOUTUBE_SETUP.md) ────────────────────────────────────────────
# Path to OAuth client JSON (type "TVs and Limited Input devices").
# Default if unset: .secrets/youtube_client_secret.json
#YOUTUBE_CLIENT_SECRET_FILE=
YOUTUBE_MAX_UPLOADS_PER_DAY=10
YOUTUBE_DAILY_QUOTA=10000

# ── Remote access (set before exposing on a VM — see DEPLOYMENT.md) ───────────
#APP_PASSWORD=
