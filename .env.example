# ════════════════════════════════════════════════════════════════
#  .env.example — copy to .env and fill in your real credentials
#  DO NOT commit .env to version control!
# ════════════════════════════════════════════════════════════════

# ── Google Gemini (AI copy generation) ───────────────────────────
# Free tier available — get your key at: https://aistudio.google.com/apikey
# Model cascade used (best → fallback):
#   1. gemini-2.5-pro          (best quality)
#   2. gemini-2.5-flash        (5 RPM free)
#   3. gemini-2.5-flash-lite   (10 RPM free)
#   4. gemini-2.0-flash        (stable fallback)
#   5. gemini-1.5-flash        (last resort)
GEMINI_API_KEY=AIzaSyYour-Key-Here

# ── Instagram Graph API ───────────────────────────────────────────
# Requires a Facebook App with instagram_basic + instagram_content_publish
# Guide: https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxx
INSTAGRAM_USER_ID=1234567890

# ── Behance (Playwright automation) ──────────────────────────────
BEHANCE_EMAIL=you@example.com
BEHANCE_PASSWORD=your_behance_password
